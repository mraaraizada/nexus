# Backend Environment Variables
# For local development
PORT=5000
NODE_ENV=development

# PostgreSQL Configuration (Local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_db
DB_USER=postgres
DB_PASSWORD=postgres

# For Render deployment with PostgreSQL:
# Set these in Render dashboard → Environment:
# NODE_ENV=production
# PORT=10000
# DATABASE_URL=postgresql://user:password@hostname.render.com/database
# FRONTEND_URL=https://your-app.vercel.app
#
# Note: DATABASE_URL is automatically provided by Render PostgreSQL
# Copy the "Internal Database URL" from your Render PostgreSQL dashboard
